# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.python-version

# Data — actual files are tracked by DVC, only .dvc pointers go to git
data/raw/*
data/processed/*
data/reference/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/reference/.gitkeep
!data/**/*.dvc
!data/**/.gitignore

# MLflow
mlruns/
mlartifacts/
mlflow.db

# DVC
/.dvc/cache
/.dvc/tmp

# IDE
.vscode/
.idea/
*.swp
.DS_Store

# Env / secrets
.env
*.env.local
kaggle.json

# Logs
logs/
*.log

# Docker
.docker/

# Jupyter
.ipynb_checkpoints/

# Test / coverage
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/
